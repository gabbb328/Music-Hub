<?xml version="1.0" encoding="utf-8"?>
<!-- PLAYER WIDGET 3x4 — Grande: copertina + info + progress + controlli -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Sfondo copertina sfocata desaturata -->
    <ImageView
        android:id="@+id/widget_bg_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_default_cover"
        android:colorFilter="@color/widget_desaturate" />

    <!-- Overlay scuro -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_overlay_gradient_dark" />

    <!-- Contenuto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="14dp">

        <!-- Copertina grande -->
        <ImageView
            android:id="@+id/widget_cover_small"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:src="@drawable/widget_default_cover"
            android:background="@drawable/widget_cover_shape_large" />

        <!-- Titolo -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Titolo canzone"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Artista -->
        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Artista"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Barra progresso -->
        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="14dp"
            android:progressDrawable="@drawable/widget_progress_bar"
            android:max="100"
            android:progress="35" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Controlli -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/widget_btn_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/widget_ic_prev"
                android:tint="#FFFFFF"
                android:contentDescription="Precedente" />

            <ImageButton
                android:id="@+id/widget_btn_play"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/widget_play_btn_bg"
                android:src="@drawable/widget_ic_play"
                android:tint="#FFFFFF"
                android:contentDescription="Play/Pausa" />

            <ImageButton
                android:id="@+id/widget_btn_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/widget_ic_next"
                android:tint="#FFFFFF"
                android:contentDescription="Successivo" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
