<?xml version="1.0" encoding="utf-8"?>
<!-- PLAYER WIDGET 4x2 — Rettangolo orizzontale: copertina + info + controlli -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Sfondo copertina sfocata desaturata -->
    <ImageView
        android:id="@+id/widget_bg_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_default_cover"
        android:colorFilter="@color/widget_desaturate" />

    <!-- Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_overlay_gradient_dark" />

    <!-- Layout orizzontale principale -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <!-- Copertina quadrata a sinistra -->
        <ImageView
            android:id="@+id/widget_cover_small"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:src="@drawable/widget_default_cover"
            android:background="@drawable/widget_cover_shape" />

        <!-- Info al centro -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titolo canzone"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Artista"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Controlli a destra -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/widget_btn_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/widget_ic_prev"
                android:tint="#FFFFFF"
                android:contentDescription="Precedente" />

            <ImageButton
                android:id="@+id/widget_btn_play"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_play_btn_bg"
                android:src="@drawable/widget_ic_play"
                android:tint="#FFFFFF"
                android:contentDescription="Play/Pausa" />

            <ImageButton
                android:id="@+id/widget_btn_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/widget_ic_next"
                android:tint="#FFFFFF"
                android:contentDescription="Successivo" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
