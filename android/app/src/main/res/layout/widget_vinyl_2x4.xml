<?xml version="1.0" encoding="utf-8"?>
<!-- VINYL WIDGET 2x4 — Vinile + info + controlli verticale -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_bg_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_default_cover"
        android:colorFilter="@color/widget_desaturate" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_overlay_gradient_dark" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="10dp">

        <!-- Vinile rotante -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp">

            <ImageView
                android:id="@+id/widget_vinyl_disc"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/widget_vinyl_default"
                android:scaleType="centerCrop" />

            <ImageButton
                android:id="@+id/widget_btn_play"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:background="@drawable/widget_play_overlay_bg"
                android:src="@drawable/widget_ic_play"
                android:tint="#FFFFFF"
                android:contentDescription="Play/Pausa" />

        </FrameLayout>

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Titolo canzone"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Artista"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/widget_btn_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/widget_ic_prev"
                android:tint="#FFFFFF"
                android:contentDescription="Precedente" />

            <ImageButton
                android:id="@+id/widget_btn_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/widget_ic_next"
                android:tint="#FFFFFF"
                android:contentDescription="Successivo" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
